{
  "name": "padel-tui",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "bin": {
    "padel-tui": "./bin/padel-tui"
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "cli": "bun run src/main.ts",
    "tui": "bun run src/main.ts tui",
    "build:exe": "bun run scripts/build-executable.ts",
    "build:exe:release": "bun run scripts/build-executable.ts --release",
    "build:exe:linux-x64": "bun run scripts/build-executable.ts --target=bun-linux-x64-baseline",
    "build:exe:linux-arm64": "bun run scripts/build-executable.ts --target=bun-linux-arm64",
    "build:exe:windows-x64": "bun run scripts/build-executable.ts --target=bun-windows-x64-baseline --outfile=dist/padel-tui.exe",
    "build:exe:darwin-arm64": "bun run scripts/build-executable.ts --target=bun-darwin-arm64 --codesign",
    "build:exe:darwin-x64": "bun run scripts/build-executable.ts --target=bun-darwin-x64 --codesign",
    "sanitize:mitm": "bun run scripts/sanitize-mitm.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@opentui/core": "^0.1.77",
    "@opentui/solid": "^0.1.77",
    "babel-preset-solid": "1.9.9",
    "cac": "^6.7.14",
    "ky": "^1.14.3",
    "solid-js": "1.9.9",
    "zod": "^4.3.6"
  }
}
